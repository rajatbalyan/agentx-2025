# Site-Sentry — copy to .env and fill in values
# Loaded automatically when using python-dotenv (e.g. CLI entry points).

# --- Required for LLM (default: NVIDIA NIM; see sentry.config.yaml llm.provider) ---
# Free tier: https://build.nvidia.com
NVIDIA_API_KEY=

# --- GitHub (PRs, branches; optional until you enable github integration) ---
GITHUB_TOKEN=

# --- Optional overrides for sentry.config.yaml (see site_sentry.config.schema.SentryConfig.load) ---
# TARGET_URL=https://example.com
# WORKSPACE_PATH=/path/to/your/repo

# --- Optional: other providers use the same env hook as SentryConfig.api_key today (NVIDIA_API_KEY).
# Install extras: langchain-google-genai, langchain-groq, langchain-openai as needed.
